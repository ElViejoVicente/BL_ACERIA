@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using GPX.Web.Data

@inject BrandingService BrandingService
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager

@if(BrandingService.IsMicrosoft365SsoEnabled && externalLogins.Length > 0) {
    <form class="external-logins" action="/Account/PerformExternalLogin" method="post">
        <AntiforgeryToken />
        <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
        @foreach(var provider in externalLogins) {
            <DxButton SubmitFormOnClick="true" name="Provider" value="@provider.Name" IconCssClass="@("icon-external-provider icon-" + provider.Name.ToLower())" Text="Acceder con Microsoft 365" RenderStyle="ButtonRenderStyle.Secondary" CssClass="w-100"></DxButton>
        }
    </form>
}

@code {
    private AuthenticationScheme[] externalLogins = [];

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync() {
        if(!BrandingService.IsMicrosoft365SsoEnabled) {
            return;
        }

        externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToArray();
    }
}
