<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Components.Layout.MainLayout)">
            <NotAuthorized>
                <AuthorizeView>
                    <Authorized Context="authorizedUser">
                        <RedirectToPage Page="/Account/AccessDenied" />
                    </Authorized>
                    <NotAuthorized Context="anonymousUser">
                        <RedirectToPage Page="/Account/Login" />
                    </NotAuthorized>
                </AuthorizeView>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
